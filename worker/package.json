{
  "name": "cloud-omproxy-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm --prefix ../web ci && npm --prefix ../web run build && wrangler deploy",
    "build": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply cloud_omproxy --local",
    "db:migrate:remote": "wrangler d1 migrations apply cloud_omproxy --remote"
  },
  "dependencies": {
    "hono": "^4.12.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.7.0"
  }
}
